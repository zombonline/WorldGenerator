<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="uk.bradleyjones.worldgenerator.WorldGeneratorController">

    <!-- Viewport -->
    <center>
        <Pane fx:id="canvasPane">
            <Canvas fx:id="worldCanvas"/>
        </Pane>
    </center>

    <!-- Left side panel -->
    <left>
        <ScrollPane fitToWidth="true" prefWidth="220" style="-fx-background-color: #1e1e1e;">
            <VBox spacing="4" style="-fx-background-color: #1e1e1e; -fx-padding: 8;">

                <!-- Regenerate button -->
                <Button fx:id="regenButton" text="Regenerate" maxWidth="Infinity"/>

                <!-- World section -->
                <TitledPane text="World" animated="true">
                    <VBox spacing="4" style="-fx-padding: 4;">
                        <Label text="Seed"/>
                        <TextField fx:id="seedInput" promptText="Seed"/>
                        <Label text="Width"/>
                        <TextField fx:id="worldWidthInput" promptText="Width"/>
                        <Label text="Height"/>
                        <TextField fx:id="worldHeightInput" promptText="Height"/>
                        <Label text="Water Level"/>
                        <TextField fx:id="waterLevelInput" promptText="Water Level"/>
                    </VBox>
                </TitledPane>

                <!-- Terrain section -->
                <TitledPane text="Terrain" animated="true">
                    <VBox spacing="4" style="-fx-padding: 4;">
                        <Label text="Base Height"/>
                        <TextField fx:id="baseHeightInput" promptText="Base Height"/>
                        <Label text="Scale A (broad)"/>
                        <TextField fx:id="noiseScaleAInput" promptText="Scale A"/>
                        <Label text="Scale B (detail)"/>
                        <TextField fx:id="noiseScaleBInput" promptText="Scale B"/>
                        <Label text="Scale C (mountain mask)"/>
                        <TextField fx:id="noiseScaleCInput" promptText="Scale C"/>
                        <Label text="Amplitude A"/>
                        <TextField fx:id="noiseAmplitudeAInput" promptText="Amplitude A"/>
                        <Label text="Amplitude B"/>
                        <TextField fx:id="noiseAmplitudeBInput" promptText="Amplitude B"/>
                        <Label text="Amplitude C (mountain)"/>
                        <TextField fx:id="noiseAmplitudeCInput" promptText="Amplitude C"/>
                    </VBox>
                </TitledPane>

                <!-- Caves section -->
                <TitledPane text="Caves" animated="true">
                    <VBox spacing="4" style="-fx-padding: 4;">
                        <Button fx:id="addCaveButton" text="+ Add Cave Generator" maxWidth="Infinity"/>
                        <VBox fx:id="caveInstancesBox" spacing="4"/>
                    </VBox>
                </TitledPane>

            </VBox>
        </ScrollPane>
    </left>

</BorderPane>